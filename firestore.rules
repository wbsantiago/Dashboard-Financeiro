rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Helper to validate standard IDs
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Validation helper for UserProfile
    function isValidUserProfile(data) {
      return data.uid is string && data.uid.size() <= 128;
    }

    // Validation helper for Expense
    function isValidExpense(data) {
      return data.id is string && data.id.size() <= 128
        && data.title is string && data.title.size() <= 150
        && data.value is number
        && data.category is string && data.category.size() <= 80
        && data.month is string && data.month.size() <= 10
        && data.date is string && data.date.size() <= 12;
    }

    // Validation helper for Revenue
    function isValidRevenue(data) {
      return data.id is string && data.id.size() <= 128
        && data.title is string && data.title.size() <= 150
        && data.value is number
        && data.category is string && data.category.size() <= 80
        && data.month is string && data.month.size() <= 10
        && data.date is string && data.date.size() <= 12;
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create, update: if isOwner(userId) && isValidUserProfile(request.resource.data);
      allow delete: if isOwner(userId);

      match /expenses/{expenseId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(expenseId) && isValidExpense(request.resource.data);
        allow update: if isOwner(userId) && isValidId(expenseId) && isValidExpense(request.resource.data);
        allow delete: if isOwner(userId);
      }

      match /revenues/{revenueId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(revenueId) && isValidRevenue(request.resource.data);
        allow update: if isOwner(userId) && isValidId(revenueId) && isValidRevenue(request.resource.data);
        allow delete: if isOwner(userId);
      }
    }
  }
}
