{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile with configuration budgets",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "defaultMonthlySalary": { "type": "number" },
        "defaultTargetSavingsPercentage": { "type": "number" },
        "categoryBudgets": {
          "type": "array"
        },
        "monthlyBudgets": {
          "type": "array"
        }
      },
      "required": ["uid"]
    },
    "Expense": {
      "title": "Expense",
      "description": "An expense item",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "value": { "type": "number" },
        "category": { "type": "string" },
        "month": { "type": "string" },
        "isInstallment": { "type": "boolean" },
        "totalInstallments": { "type": "number" },
        "currentInstallment": { "type": "number" },
        "firstInstallmentInNextMonth": { "type": "boolean" },
        "date": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "title", "value", "category", "month", "date"]
    },
    "Revenue": {
      "title": "Revenue",
      "description": "A revenue item",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "value": { "type": "number" },
        "category": { "type": "string" },
        "month": { "type": "string" },
        "date": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "title", "value", "category", "month", "date"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "UserProfile",
      "description": "General settings and budgets of the users"
    },
    "users/{userId}/expenses/{expenseId}": {
      "schema": "Expense",
      "description": "User specific expenses"
    },
    "users/{userId}/revenues/{revenueId}": {
      "schema": "Revenue",
      "description": "User specific revenues"
    }
  }
}
